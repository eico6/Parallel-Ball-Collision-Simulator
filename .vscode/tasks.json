{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "g++",
      "args": [
          "-std=gnu++23",
          "-g",
          "-Wall",
          "-Wextra",
          "*.cpp",
          "-IC:/raylib/include",
          "-LC:/raylib/lib",
          "-o", "app",
          "-lraylib",
          "-lopengl32",
          "-lgdi32",
          "-lwinmm"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
